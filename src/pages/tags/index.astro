---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagCloud from '../../components/TagCloud.astro';
import { getPublishedArticles, getTagCounts } from '../../lib/content';

const allArticles = await getPublishedArticles();
const tagCounts = await getTagCounts();
---
<BaseLayout title="Tags">
  <h1 style="font-family: 'Playfair Display', serif; font-size: 2rem; margin-bottom: 0.75rem;">All Tags</h1>
  <p style="color: var(--muted); margin-bottom: 1.5rem;">{Object.keys(tagCounts).length} topics across {allArticles.length} articles.</p>
  <TagCloud tags={tagCounts} />
</BaseLayout>
