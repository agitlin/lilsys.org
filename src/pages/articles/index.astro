---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedArticles } from '../../lib/content';

const articles = await getPublishedArticles();
---
<BaseLayout title="Articles">
  <h1 style="font-family: 'Playfair Display', serif; font-size: 2rem; margin-bottom: 2rem;">Articles</h1>
  <ul class="article-list">
    {articles.map(article => (
      <li class="article-item">
        <h2><a href={`/articles/${article.slug}`}>{article.data.title}</a></h2>
        <div class="article-meta">{article.data.date}</div>
        {article.data.description && <p class="article-desc">{article.data.description}</p>}
        <div class="tag-cloud" style="margin-top: 0.5rem;">
          {article.data.tags.map(tag => (
            <a href={`/tags/${tag}`} class="tag">{tag}</a>
          ))}
        </div>
      </li>
    ))}
  </ul>
</BaseLayout>
