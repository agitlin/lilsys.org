---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAboutArticle } from '../lib/content';

// The About page renders whichever article is tagged `about` (enforced unique
// at build time in lib/content.ts), so it's editable in the CMS like any post.
const about = await getAboutArticle();
const { Content } = about ? await about.render() : { Content: null };
---
<BaseLayout title="About" description={about?.data.description}>
  <article class="prose">
    <div class="article-header"><h1>{about?.data.title ?? 'About'}</h1></div>
    {Content ? <Content /> : <p>No article is tagged <code>about</code> yet.</p>}
  </article>
</BaseLayout>
